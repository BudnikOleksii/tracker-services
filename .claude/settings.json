{
  "permissions": {
    "deny": ["Read(!.env.example)", "Read(.env*)", "Read(.npmrc)"]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.rulesync/hooks/format.sh"
          }
        ]
      }
    ]
  }
}
